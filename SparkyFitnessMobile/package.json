{
  "name": "sparkyfitnessmobile",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "start": "expo start",
    "test": "jest",
    "test:run": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@kingstinct/react-native-healthkit": "^13.3.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/stack": "^7.4.2",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/react-query": "^5.90.20",
    "@workspace/shared": "workspace:*",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-background-task": "~1.0.10",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "^6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-health-connect": "^0.1.1",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.2.7",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~10.0.0",
    "expo-atlas": "^0.4.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "2.8.8",
    "radon-ide": "^0.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "__tests__/hooks/queryTestUtils\\.ts$"
    ],
    "moduleNameMapper": {
      "^@workspace/shared$": "<rootDir>/../shared/src/index.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/[^/]+/node_modules/)?((jest-)?react-native|@react-native(-community)?|expo[^/]*|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@shopify/react-native-skia|react-native-ui-datepicker|@workspace/shared|zod)/)"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{ts,tsx,js,jsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/metro.config.js",
      "!**/.prettierrc.js",
      "!**/eslint.config.js",
      "!**/expo-env.d.ts",
      "!**/.expo/**"
    ]
  }
}
