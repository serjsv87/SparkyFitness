{
  "expo": {
    "name": "SparkyFitnessMobile",
    "slug": "sparkyfitnessmobile",
    "version": "1.3.2",
    "scheme": "sparkyfitnessmobile",
    "orientation": "portrait",
    "icon": "./assets/icons/appstore.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "SparkyFitness reads Health data (such as activity, workouts, and body measurements) to display it in the app and sync it to your self-hosted SparkyFitness server.",
          "background": true
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect",
      "expo-web-browser",
      "expo-font",
      "expo-asset",
      "expo-background-task",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "SparkyFitness needs access to your camera to scan food barcodes and labels.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#e2e2e2",
          "imageWidth": 200,
          "image": "./assets/images/splash.png",
          "dark": {
            "backgroundColor": "#232323",
            "image": "./assets/images/splash.png"
          }
          
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "eas": {
        "projectId": "498a86c5-344f-4d2c-9033-dfd720e4a383"
      },
      "APP_VARIANT": "production"
    }
  }
}
